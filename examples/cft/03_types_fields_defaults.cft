# Types define schema objects. Fields use semicolons and may have defaults.

@struct
sealed type ExampleVector2 {
  x: float;
  y: float;
}
type ExampleItem {
  name: string;

  rarity: ExampleRarity = ExampleRarity.Common;

  price: int = 0;
  tags: [string] = [];

  check {
    id != "";
    name != "";
    price >= 0;
    none tag in tags { tag == ""; }
  }
}
