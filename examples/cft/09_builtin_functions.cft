# Built-in functions are available in check expressions.

type ExampleBuiltinFunctions {
  numbers: [int] = [];
  names: [string] = [];
  scores: {string: int} = {};

  check {
    id.matches("^[a-z][a-z0-9_]*$");
    numbers.len() >= 0;
    numbers.sum() >= 0;
    names.isUnique();
    names.contains("default");
    scores.contains("default");
    scores.keys().len() == scores.values().len();

    when numbers.len() > 0 {
      numbers.min() <= numbers.max();
    }
  }
}
