class Modifier {
  id: string
  weights: dict[string, [float]]
}

class SkillTree {
  roots: [[string]]
  metadata: dict[string, dict[string, string]]
  modifier: Modifier = {
    id: "base",
    weights: {
      "damage": [[1.0, 1.5], [2.0]],
    },
  }

  check {
    self.roots[0][0] != "" => "empty root"
  }
}

nested_lists = [
  [[1, 2, 3], [4, 5, 6]],
  [[7], [8, 9]],
];

nested_dict: dict[string, dict[string, [int]]] = {
  "alpha": {
    "levels": [1, 2, 3],
  },
  "beta": {
    "levels": [4, 5, 6],
  },
};

var resolver = fn(entity) {
  var pick = fn(path,) {
    return entity.data[path[0]][path[1]];
  };
  return pick(["stats", "hp"]);
};
