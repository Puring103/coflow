# loop、until、iter fn 新语法

var MAX_RETRIES = 3;

fn retry(action: any) -> bool {
  var attempts = 0;
  loop {
    attempts += 1;
    if action() {
      return true;
    }
    if attempts >= MAX_RETRIES {
      break;
    }
  }
  return false;
}

fn drain(queue: any) {
  until queue.empty() {
    queue.pop();
  }
}

iter fn take_while(source, pred) {
  for item in source {
    if not pred(item) {
      return;
    }
    yield item;
  }
}

iter fn enumerate(source) {
  var i = 0;
  for item in source {
    yield { index: i, value: item };
    i += 1;
  }
}

fn use_iterators() {
  for entry in enumerate([10, 20, 30]) {
    print(entry.index);
    print(entry.value);
  }
}
