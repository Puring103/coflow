# 整数除法、幂运算、位运算、range

fn math_ops(a: int, b: int) -> int {
  let q = a // b
  let p = a ** b
  let shifted = a << 2
  let rshifted = a >> 1
  return q + p + shifted + rshifted
}

fn bitwise_flags(flags: int) -> int {
  let DEAD    = 0b0001
  let STUNNED = 0b0010
  let FROZEN  = 0b0100

  var status = DEAD | STUNNED
  var cleared = status & ~STUNNED
  var toggled = status ^ FROZEN
  return cleared + toggled
}

fn range_ops() {
  for i in 0..10 {
    print(i)
  }

  for i in 0..=5 {
    print(i)
  }

  if 3 in 0..10 {
    print("in range")
  }
}

fn chained_cmp(damage: int) -> bool {
  return 0 < damage <= 100
}
