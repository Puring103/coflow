import common
import effects as fx

enum Rarity {
  common
  rare
  epic
}

class Requirement {
  level: int
  tags: [string]

  check {
    self.level >= 0 => "level must be >= 0"
  }
}

class Skill {
  id: string
  name: string
  rarity: Rarity
  damage: int
  cooldown: float = 1.0
  requirement: Requirement
  costs: dict[string, int]
  effects: [any]
  metadata: dict[string, any]

  check {
    self.damage > 0 => "damage must be positive"
  }
}

base_damage = 0x1e
default_requirement: Requirement = {
  level: 3,
  tags: ["mage", "fire"],
}

fireball: Skill = {
  id: "fireball",
  name: "Fireball",
  rarity: Rarity.rare,
  damage: base_damage + 10,
  requirement: default_requirement,
  costs: {
    "mana": 25,
    "stamina": 0,
  },
  effects: [
    {
      id: "burn",
      duration: 3.5,
      apply: fn(target) {
        target.hp -= 5
        return target.hp
      },
    },
    {
      id: "knockback",
      vector: [0, 1, 0],
      nested: {
        stages: [
          {
            delay: 0.0,
            action: "start",
          },
          {
            delay: 0.5,
            action: "push",
          },
        ],
      },
    },
  ],
  metadata: {
    "icon": r"C:\game\icons\fireball.png",
    "description": """
Launches a fire projectile.
Can burn the target.
""",
    "source": common.defaults.skill_source,
  },
}

iter fn cooldown_ticks(skill, count) {
  var i = 0
  while i < count {
    yield {
      id: skill.id,
      tick: i,
      remaining: skill.cooldown - i,
    }
    i += 1
  }
}

fn apply_skill(skill, caster, target) {
  var name = target?.name ?? "unknown"
  name ??= "unknown"

  if "fire" in skill.requirement.tags and not target.dead {
    target.hp -= skill.damage
    fx.spawn(skill.effects[0].id, target.position)
  }

  return {
    target: name,
    hp: target.hp,
    done: target.hp <= 0,
  }
}
