<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    Coflow Tools Hardened Runtime entitlements.

    Tauri renders the UI in WKWebView, which requires the JIT and unsigned
    executable memory entitlements. The updater and any HTTP-backed provider
    need outgoing network. The bundled `coflow` sidecar is signed with the
    same identity, so we do not need library-validation exemptions.
  -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.network.client</key>
  <true/>
</dict>
</plist>
