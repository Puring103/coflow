{% for parameter in project.database.constructor_parameters %}        {{ parameter.ty }} {{ parameter.name }}{% if not loop.last or project.singletons | length > 0 %},{% endif %}
{% endfor %}{% for s in project.singletons %}        {{ s.type_name }} {{ s.records_var }}{% if not loop.last %},{% endif %}
