fn sum_positive(items) {
  var total = 0;

  for item in items {
    if item < 0 {
      continue;
    } else if item == 0 {
      total += 0;
    } else {
      total += item;
    }
  }

  return total;
}

fn countdown(start) {
  var n = start;

  while n > 0 {
    n -= 1;
    if n == 2 {
      break;
    }
  }

  return n;
}
