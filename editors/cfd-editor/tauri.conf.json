{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CFD Editor",
  "version": "0.1.0",
  "identifier": "dev.coflow.cfd-editor",
  "build": {
    "beforeDevCommand": "npm --prefix frontend run dev",
    "beforeBuildCommand": "npm --prefix frontend run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "frontend/dist"
  },
  "app": {
    "windows": [{ "title": "CFD Editor", "width": 1280, "height": 800, "resizable": true }],
    "security": { "csp": null }
  },
  "bundle": { "active": true, "targets": "all", "icon": ["icons/icon.ico"] },
  "plugins": {}
}
