  "bundle": {
    "active": false,
    "targets": "all"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQzOUQ2MUE5QTYwQTRGQjAKUldTd1R3cW1xV0dkMHh3MVAvNzhRdWR0alppR1Z4aXM0azRFbGhWZVFWT01IMzQveEpqaVh0c1UK",
      "endpoints": [
        "https://github.com/Puring103/coflow/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
