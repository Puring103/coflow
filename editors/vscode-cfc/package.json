{
  "name": "vscode-cfc",
  "displayName": "CFC Language Support",
  "description": "Syntax highlighting and diagnostics for the CFC configuration language.",
  "version": "0.0.1",
  "publisher": "coflow",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:cfc"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cfc.checkFile",
        "title": "CFC: Check Current File"
      }
    ],
    "configuration": {
      "title": "CFC",
      "properties": {
        "cfc.cliPath": {
          "type": "string",
          "default": "cfc",
          "description": "Path to the cfc CLI executable."
        },
        "cfc.checkOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run cfc check when a .cfc file is saved."
        },
        "cfc.checkOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Run cfc check when a .cfc file is opened."
        }
      }
    },
    "languages": [
      {
        "id": "cfc",
        "aliases": [
          "CFC",
          "cfc"
        ],
        "extensions": [
          ".cfc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cfc",
        "scopeName": "source.cfc",
        "path": "./syntaxes/cfc.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "cfc",
        "path": "./snippets/cfc.json"
      }
    ]
  }
}
