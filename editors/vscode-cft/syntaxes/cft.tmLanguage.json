{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CFT",
  "scopeName": "source.cft",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#annotations"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#builtin-types"
    },
    {
      "include": "#builtin-functions"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#user-types"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "annotations": {
      "patterns": [
        {
          "name": "storage.modifier.annotation.cft",
          "match": "@(struct|flag|id|ref|index|display|deprecated)\\b"
        },
        {
          "name": "invalid.illegal.annotation.cft",
          "match": "@[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "builtin-functions": {
      "patterns": [
        {
          "name": "support.function.builtin.cft",
          "match": "\\b(len|contains|unique|min|max|sum|keys|values|matches)\\b(?=\\s*\\()"
        }
      ]
    },
    "builtin-types": {
      "patterns": [
        {
          "name": "storage.type.primitive.cft",
          "match": "\\b(int|float|bool|string)\\b"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.cft",
          "match": "^\\s*//.*$|(?<=[;}\\],])\\s*//.*$"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.cft",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.declaration.const.cft",
          "match": "\\b(const)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.type.const.cft"
            },
            "2": {
              "name": "entity.name.constant.cft"
            }
          }
        },
        {
          "name": "meta.declaration.enum.cft",
          "match": "\\b(enum)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.type.enum.cft"
            },
            "2": {
              "name": "entity.name.type.enum.cft"
            }
          }
        },
        {
          "name": "meta.declaration.type.cft",
          "match": "\\b((?:(?:abstract|sealed)\\s+)*)(type)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.modifier.cft"
            },
            "2": {
              "name": "storage.type.cft"
            },
            "3": {
              "name": "entity.name.type.cft"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.cft",
          "match": "\\b(check|when|all|any|none|in|is)\\b"
        },
        {
          "name": "storage.modifier.cft",
          "match": "\\b(abstract|sealed)\\b"
        },
        {
          "name": "storage.type.cft",
          "match": "\\b(const|enum|type)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.cft",
          "match": "\\b[0-9]+\\.[0-9]+(?:[eE][+-]?[0-9]+)?\\b|\\b[0-9]+[eE][+-]?[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.cft",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.cft",
          "match": "==|!=|<=|>=|<<|>>|&&|\\|\\||//|\\*\\*|[+\\-*/%<>=!~&|^?:.]"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.cft",
          "match": "[;,]"
        },
        {
          "name": "punctuation.section.cft",
          "match": "[{}\\[\\]()]"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.cft",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.cft",
              "match": "\\\\[\"\\\\nrt]"
            },
            {
              "name": "invalid.illegal.escape.cft",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "user-types": {
      "patterns": [
        {
          "name": "support.type.user-defined.cft",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
