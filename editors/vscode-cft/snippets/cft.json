{
  "const": {
    "prefix": "const",
    "body": ["const ${1:NAME}: ${2:int} = ${3:value};"],
    "description": "Define a compile-time CFT constant."
  },
  "enum": {
    "prefix": "enum",
    "body": ["enum ${1:Name} {", "\t${2:Variant},", "}"],
    "description": "Define a CFT enum."
  },
  "flag enum": {
    "prefix": "flag",
    "body": [
      "@flag",
      "enum ${1:Name} {",
      "\t${2:Read} = 1,",
      "\t${3:Write} = 2,",
      "}"
    ],
    "description": "Define a @flag enum."
  },
  "type": {
    "prefix": "type",
    "body": ["type ${1:Name} {", "\t${2:field}: ${3:string};", "}"],
    "description": "Define a CFT type."
  },
  "abstract type": {
    "prefix": "abstract",
    "body": ["abstract type ${1:Name} {", "\t${2:field}: ${3:string};", "}"],
    "description": "Define an abstract CFT type."
  },
  "sealed type": {
    "prefix": "sealed",
    "body": ["sealed type ${1:Name} {", "\t${2:field}: ${3:string};", "}"],
    "description": "Define a sealed CFT type."
  },
  "check block": {
    "prefix": "check",
    "body": ["check {", "\t${1:condition};", "}"],
    "description": "Define a check block."
  },
  "when block": {
    "prefix": "when",
    "body": ["when ${1:condition} {", "\t${2:condition};", "}"],
    "description": "Define a conditional check block."
  },
  "all quantifier": {
    "prefix": "all",
    "body": ["all ${1:item} in ${2:items} {", "\t${3:condition};", "}"],
    "description": "Define an all quantifier check."
  },
  "any quantifier": {
    "prefix": "any",
    "body": ["any ${1:item} in ${2:items} {", "\t${3:condition};", "}"],
    "description": "Define an any quantifier check."
  },
  "none quantifier": {
    "prefix": "none",
    "body": ["none ${1:item} in ${2:items} {", "\t${3:condition};", "}"],
    "description": "Define a none quantifier check."
  },
  "ref annotation": {
    "prefix": "@ref",
    "body": ["@ref(${1:TypeName})"],
    "description": "Annotate a string or int field as a reference."
  },
  "display annotation": {
    "prefix": "@display",
    "body": ["@display(\"${1:text}\")"],
    "description": "Attach a display name."
  }
}
