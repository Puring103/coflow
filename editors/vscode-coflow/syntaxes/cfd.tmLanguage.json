{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CFD",
  "scopeName": "source.cfd",
  "patterns": [
    { "include": "#comment-slash" },
    { "include": "#comment-hash" },
    { "include": "#string" },
    { "include": "#spread" },
    { "include": "#ref-direct" },
    { "include": "#record-colon" },
    { "include": "#group-key" },
    { "include": "#type-before-brace" },
    { "include": "#field-name" },
    { "include": "#constant-language" },
    { "include": "#constant-numeric" },
    { "include": "#user-type" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comment-slash": {
      "name": "comment.line.double-slash.cfd",
      "match": "//.*$"
    },
    "comment-hash": {
      "name": "comment.line.number-sign.cfd",
      "match": "#.*$"
    },
    "string": {
      "name": "string.quoted.double.cfd",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.cfd", "match": "\\\\[\"\\\\nrt]" }
      ]
    },
    "spread": {
      "name": "keyword.operator.spread.cfd",
      "match": "\\.\\.\\."
    },
    "ref-direct": {
      "comment": "&key — direct reference shorthand; & merged into variable capture",
      "match": "(&[A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "variable.other.readwrite.cfd" }
      }
    },
    "record-colon": {
      "comment": "key: TypeName {  — top-level or group-polymorphic record",
      "match": "^(\\s*)([A-Za-z_][A-Za-z0-9_]*)\\s*(:)\\s*([A-Za-z_][A-Za-z0-9_]*)(?=\\s*\\{)",
      "captures": {
        "2": { "name": "entity.name.tag.cfd" },
        "3": { "name": "punctuation.separator.key-value.cfd" },
        "4": { "name": "entity.name.type.cfd" }
      }
    },
    "group-key": {
      "comment": "snake_case_key {  — group member (lowercase-only) inheriting type from header",
      "match": "^\\s*([a-z_][A-Za-z0-9_]*)\\s*(?=\\{)",
      "captures": {
        "1": { "name": "entity.name.tag.cfd" }
      }
    },
    "type-before-brace": {
      "comment": "TypeName {  — inline polymorphic type marker or group header",
      "match": "\\b([A-Z][A-Za-z0-9_]*)(?=\\s*\\{)",
      "captures": {
        "1": { "name": "entity.name.type.cfd" }
      }
    },
    "field-name": {
      "comment": "fieldName:  — object field or dict key (lowercase)",
      "match": "\\b([a-z_][A-Za-z0-9_]*)(?=\\s*:)",
      "captures": {
        "1": { "name": "entity.other.attribute-name.cfd" }
      }
    },
    "constant-language": {
      "name": "constant.language.cfd",
      "match": "\\b(null|true|false)\\b"
    },
    "constant-numeric": {
      "name": "constant.numeric.cfd",
      "match": "-?(?:\\d+\\.\\d*|\\d*\\.\\d+|\\d+)(?:[eE][+-]?\\d+)?"
    },
    "user-type": {
      "comment": "Catch-all: enum variant values, bare type names — any remaining PascalCase identifier",
      "name": "support.type.user-defined.cfd",
      "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.definition.block.cfd", "match": "[{}]" },
        { "name": "punctuation.definition.array.cfd", "match": "[\\[\\]]" },
        { "name": "punctuation.separator.cfd", "match": "[,;]" },
        { "name": "punctuation.separator.key-value.cfd", "match": ":" }
      ]
    }
  }
}
