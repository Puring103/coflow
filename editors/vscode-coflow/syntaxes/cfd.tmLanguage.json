{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CFD",
  "scopeName": "source.cfd",
  "patterns": [
    { "include": "#comment-line-slash" },
    { "include": "#comment-line-hash" },
    { "include": "#string" },
    { "include": "#constant-language" },
    { "include": "#constant-numeric" },
    { "include": "#spread" },
    { "include": "#ref-typed" },
    { "include": "#ref-direct" },
    { "include": "#record-key-colon" },
    { "include": "#type-name" },
    { "include": "#field-name" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comment-line-slash": {
      "name": "comment.line.double-slash.cfd",
      "match": "//.*$"
    },
    "comment-line-hash": {
      "name": "comment.line.number-sign.cfd",
      "match": "#.*$"
    },
    "string": {
      "name": "string.quoted.double.cfd",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.cfd",
          "match": "\\\\[\"\\\\nrt]"
        }
      ]
    },
    "constant-language": {
      "name": "constant.language.cfd",
      "match": "\\b(null|true|false)\\b"
    },
    "constant-numeric": {
      "name": "constant.numeric.cfd",
      "match": "-?\\b(?:\\d+\\.\\d*|\\d*\\.\\d+|\\d+)(?:[eE][+-]?\\d+)?\\b"
    },
    "spread": {
      "name": "keyword.operator.spread.cfd",
      "match": "\\.\\.\\."
    },
    "ref-typed": {
      "name": "meta.ref.typed.cfd",
      "match": "@([A-Za-z_][A-Za-z0-9_]*)\\.([A-Za-z0-9_.-]*)",
      "captures": {
        "1": { "name": "entity.name.type.cfd" },
        "2": { "name": "variable.other.cfd" }
      }
    },
    "ref-direct": {
      "name": "meta.ref.direct.cfd",
      "match": "&([A-Za-z0-9_][A-Za-z0-9_.-]*)",
      "captures": {
        "1": { "name": "variable.other.cfd" }
      }
    },
    "record-key-colon": {
      "comment": "Top-level record: key: TypeName { ... }  or grouped record key { ... }",
      "name": "meta.record.cfd",
      "match": "^\\s*([A-Za-z_\"][^:{\\s][^:{]*?)\\s*(:)\\s*([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "entity.name.namespace.cfd" },
        "2": { "name": "punctuation.separator.cfd" },
        "3": { "name": "entity.name.type.cfd" }
      }
    },
    "type-name": {
      "comment": "Type marker before a block, e.g. SubType { ... }",
      "name": "entity.name.type.cfd",
      "match": "\\b([A-Z][A-Za-z0-9_]*)\\s*(?=\\{)"
    },
    "field-name": {
      "comment": "field: value",
      "name": "variable.other.property.cfd",
      "match": "\\b([a-z_][A-Za-z0-9_]*)\\s*(?=:)"
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.definition.block.cfd", "match": "[{}]" },
        { "name": "punctuation.definition.array.cfd", "match": "[\\[\\]]" },
        { "name": "punctuation.separator.cfd", "match": "[,;:]" }
      ]
    }
  }
}
