{
  "name": "coflow",
  "displayName": "Coflow Language Support",
  "description": "Syntax highlighting, snippets, hovers, and completions for Coflow Type File (.cft) and Coflow Data File (.cfd).",
  "version": "0.1.0",
  "publisher": "coflow",
  "license": "MIT OR Apache-2.0",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "cft",
    "cfd",
    "coflow",
    "schema",
    "game-data"
  ],
  "activationEvents": [
    "onLanguage:cft",
    "onLanguage:cfd",
    "onCommand:coflow.openCfdInspector"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "coflow.openCfdInspector",
        "title": "Open CFD Inspector",
        "category": "Coflow",
        "icon": "$(open-preview)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "coflow.openCfdInspector",
          "when": "resourceLangId == cfd",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": {
      "title": "Coflow",
      "properties": {
        "coflow.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable diagnostics from the Coflow language server."
        },
        "coflow.diagnostics.command": {
          "type": "string",
          "default": "coflow",
          "description": "Command used to start the Coflow language server."
        },
        "coflow.diagnostics.args": {
          "type": "array",
          "default": [
            "lsp"
          ],
          "items": {
            "type": "string"
          },
          "description": "Arguments used to start the project-aware Coflow language server."
        },
        "coflow.diagnostics.debounceMs": {
          "type": "number",
          "default": 350,
          "minimum": 0,
          "description": "Delay before diagnostics run after document edits."
        }
      }
    },
    "languages": [
      {
        "id": "cft",
        "aliases": [
          "CFT",
          "Coflow Type File"
        ],
        "extensions": [
          ".cft"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "cfd",
        "aliases": [
          "CFD",
          "Coflow Data File"
        ],
        "extensions": [
          ".cfd"
        ],
        "configuration": "./cfd-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cft",
        "scopeName": "source.cft",
        "path": "./syntaxes/cft.tmLanguage.json"
      },
      {
        "language": "cfd",
        "scopeName": "source.cfd",
        "path": "./syntaxes/cfd.tmLanguage.json"
      }
    ],
    "semanticTokenModifiers": [
      {
        "id": "reference",
        "description": "A symbol reference."
      },
      {
        "id": "path",
        "description": "A field or index segment inside a reference path."
      },
      {
        "id": "record",
        "description": "A CFD record key or record reference."
      },
      {
        "id": "schema",
        "description": "A schema type, field, enum, or related reference."
      }
    ],
    "configurationDefaults": {
      "editor.semanticHighlighting.enabled": true,
      "editor.semanticTokenColorCustomizations": {
        "rules": {
          "namespace.declaration.record:cfd": {
            "foreground": "#4EC9B0",
            "fontStyle": "bold"
          },
          "namespace.reference.record:cfd": {
            "foreground": "#9CDCFE"
          },
          "property.declaration.schema:cfd": {
            "foreground": "#DCDCAA"
          },
          "property.reference.path.schema:cfd": {
            "foreground": "#C586C0"
          },
          "type.reference.schema:cfd": {
            "foreground": "#4EC9B0"
          },
          "property.declaration.schema:cft": {
            "foreground": "#DCDCAA"
          },
          "property.reference.path.schema:cft": {
            "foreground": "#C586C0"
          },
          "type.declaration.schema:cft": {
            "foreground": "#4EC9B0",
            "fontStyle": "bold"
          },
          "type.reference.schema:cft": {
            "foreground": "#4EC9B0"
          },
          "enum.declaration.schema:cft": {
            "foreground": "#B8D7A3",
            "fontStyle": "bold"
          },
          "enumMember.declaration.schema:cft": {
            "foreground": "#B8D7A3"
          },
          "enumMember.reference.schema:cft": {
            "foreground": "#B8D7A3"
          }
        }
      }
    },
    "snippets": [
      {
        "language": "cft",
        "path": "./snippets/cft.json"
      },
      {
        "language": "cfd",
        "path": "./snippets/cfd.json"
      }
    ]
  }
}
